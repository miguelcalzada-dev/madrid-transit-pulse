# Variables de entorno del Frontend Next.js
# Copia a .env.local y ajusta los valores

# URL base del backend API (REST + WebSocket)
# ⚠️  NO añadas /api al final — el código lo añade automáticamente.
# Local:
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Producción (Render / Railway / Fly.io, etc.):
# NEXT_PUBLIC_API_URL=https://tu-backend.onrender.com
# NEXT_PUBLIC_WS_URL=https://tu-backend.onrender.com

# Coordenadas del centro del mapa de Madrid
NEXT_PUBLIC_MAP_CENTER_LAT=40.4168
NEXT_PUBLIC_MAP_CENTER_LON=-3.7038
