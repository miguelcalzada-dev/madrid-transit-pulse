# Variables de entorno del Frontend Next.js
# Copia a .env.local y ajusta los valores

# URL del backend API (REST)
NEXT_PUBLIC_API_URL=http://localhost:3001

# URL del servidor WebSocket (Socket.io)
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Coordenadas del centro del mapa de Madrid
NEXT_PUBLIC_MAP_CENTER_LAT=40.4168
NEXT_PUBLIC_MAP_CENTER_LON=-3.7038
