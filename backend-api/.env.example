# ============================================================
# .env.example - Variables de entorno del Backend API
# Madrid Transit Pulse
# ============================================================
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el .env real al control de versiones.
# ============================================================

# Servidor
PORT=3001
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://mtp_app:mtp_secure_pass@localhost:27017/madrid_transit?authSource=madrid_transit
MONGO_DB_NAME=madrid_transit

# CORS: orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Polling de alertas para WebSocket (milisegundos)
# En producción usar MongoDB Change Streams (requiere replica set)
ALERTS_POLL_INTERVAL_MS=5000

# Límite de alertas devueltas por el endpoint /api/status
ALERTS_LIMIT=50

# Rate limiting: máx peticiones por IP en la ventana
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
